# Cloudflare Pages response headers.
# https://developers.cloudflare.com/pages/configuration/headers/

# ── Security headers — applied to every URL ──────────────────────────────
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://www.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com https://cloudflareinsights.com https://*.cloudflareinsights.com; frame-src 'self' https://www.google.com https://maps.google.com https://*.google.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self' mailto:

# ── HTML pages — short cache so content updates propagate fast ───────────
/
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate

# ── Astro fingerprinted assets — immutable, year-long cache ──────────────
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# ── Scripts (carousel.js etc.) — 1 day; not fingerprinted but rarely changes
/scripts/*
  Cache-Control: public, max-age=86400, must-revalidate

# ── Images — 30 day cache; rebuilds re-deploy with same name ─────────────
/images/*
  Cache-Control: public, max-age=2592000, must-revalidate

/*.png
  Cache-Control: public, max-age=2592000, must-revalidate

/*.jpg
  Cache-Control: public, max-age=2592000, must-revalidate

/*.jpeg
  Cache-Control: public, max-age=2592000, must-revalidate

/*.webp
  Cache-Control: public, max-age=2592000, must-revalidate

/*.avif
  Cache-Control: public, max-age=2592000, must-revalidate

/*.svg
  Cache-Control: public, max-age=2592000, must-revalidate

# ── Crawler files — short cache so updates propagate within an hour ──────
/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=3600

/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

/sitemap-index.xml
  Cache-Control: public, max-age=3600

/sitemap-*.xml
  Cache-Control: public, max-age=3600
