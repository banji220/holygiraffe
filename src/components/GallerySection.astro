---
// Marquee gallery — two infinite-scroll rows of photos.
//  Top row scrolls left, bottom row scrolls right.
//  Photos pause on hover (CSS animation-play-state).
//  No before/after pairing needed — drop ANY photos (work shots, vans,
//  team, results) at the paths below and they appear in rotation.
//
// PHOTO PATHS (drop files at /public/images/gallery/):
//   photo-1.jpg through photo-12.jpg
//   Recommended: landscape JPG/WebP, ~600×400, ≤150 KB each.
//
// If a file is missing, the tile renders as a "Photo coming" placeholder
// so the marquee still flows visually while you populate it.

// All 21 photos in /public/images/gallery/ — split across two marquee rows
// so each row has enough photos to feel continuous and you don't see the
// same photo cycle obviously within a single viewport width.
const rowTop = [
  '/images/gallery/photo-1.jpg',
  '/images/gallery/photo-3.jpg',
  '/images/gallery/photo-5.jpg',
  '/images/gallery/photo-7.jpg',
  '/images/gallery/photo-9.jpg',
  '/images/gallery/photo-11.jpg',
  '/images/gallery/photo-13.jpg',
  '/images/gallery/photo-15.jpg',
  '/images/gallery/photo-17.jpg',
  '/images/gallery/photo-19.jpg',
  '/images/gallery/photo-21.jpg',
];

const rowBottom = [
  '/images/gallery/photo-2.jpg',
  '/images/gallery/photo-4.jpg',
  '/images/gallery/photo-6.jpg',
  '/images/gallery/photo-8.jpg',
  '/images/gallery/photo-10.jpg',
  '/images/gallery/photo-12.jpg',
  '/images/gallery/photo-14.jpg',
  '/images/gallery/photo-16.jpg',
  '/images/gallery/photo-18.jpg',
  '/images/gallery/photo-20.jpg',
];

// Duplicate each row so the marquee can loop seamlessly (translateX -50%
// of the doubled set returns to the visual start position).
---

<section class="py-12 sm:py-16 md:py-20 bg-card relative overflow-hidden" aria-label="Recent work gallery">
  <div class="container mx-auto px-4 sm:px-6">
    <div class="text-center mb-10 sm:mb-14 max-w-2xl mx-auto">
      <div class="neo-badge bg-coral text-coral-foreground mb-4 mx-auto">📸 Recent Work</div>
      <h2 class="text-4xl md:text-6xl font-heading font-bold">
        From Our Crews Across <span class="text-primary">Orange County</span>
      </h2>
      <p class="text-muted-foreground text-lg mt-4">
        Hover to pause. Real jobs, real homes, real glass. From beach
        cottages to canyon estates.
      </p>
    </div>
  </div>

  {/* Top row — scrolls LEFT (default marquee direction).
      overflow-hidden on the parent clips off-screen photos.
      flex-shrink-0 on each tile keeps them from squishing. */}
  <div class="overflow-hidden mb-4 sm:mb-6 marquee-row">
    <div class="flex gap-4 sm:gap-6 animate-marquee-gallery w-max">
      {[...rowTop, ...rowTop].map((src, i) => (
        <figure class="shrink-0 w-[220px] sm:w-[280px] md:w-[320px] aspect-[4/3] rounded-2xl overflow-hidden bg-muted/30 relative shadow-sm transition-transform duration-300 hover:scale-[1.02]">
          <img
            src={src}
            alt="Giraffe Window Cleaning recent work in Orange County, CA"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
          />
          <div
            class="hidden w-full h-full items-center justify-center text-muted-foreground text-xs font-heading font-semibold uppercase tracking-wider"
            aria-hidden="true"
          >
            Photo coming
          </div>
        </figure>
      ))}
    </div>
  </div>

  {/* Bottom row — scrolls RIGHT (reverse marquee), slightly slower. */}
  <div class="overflow-hidden marquee-row">
    <div class="flex gap-4 sm:gap-6 animate-marquee-gallery-reverse w-max">
      {[...rowBottom, ...rowBottom].map((src, i) => (
        <figure class="shrink-0 w-[220px] sm:w-[280px] md:w-[320px] aspect-[4/3] rounded-2xl overflow-hidden bg-muted/30 relative shadow-sm transition-transform duration-300 hover:scale-[1.02]">
          <img
            src={src}
            alt="Giraffe Window Cleaning recent work in Orange County, CA"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
          />
          <div
            class="hidden w-full h-full items-center justify-center text-muted-foreground text-xs font-heading font-semibold uppercase tracking-wider"
            aria-hidden="true"
          >
            Photo coming
          </div>
        </figure>
      ))}
    </div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 mt-8 sm:mt-10 text-center">
    <p class="text-sm text-muted-foreground">
      Want your home featured here?
      <a href="/get-a-quote" class="text-primary font-heading font-bold underline hover:text-primary/80 transition-colors">Book a clean →</a>
    </p>
  </div>
</section>

{/* Hover-pause for the marquee. Pure CSS — no JS. */}
<style>
  .marquee-row:hover > div {
    animation-play-state: paused;
  }
  /* Respect users who've set Reduce Motion in their OS — don't animate. */
  @media (prefers-reduced-motion: reduce) {
    .marquee-row > div {
      animation: none;
      transform: translateX(0);
    }
  }
</style>
