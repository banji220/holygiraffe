---
// Google Maps embed using the legacy `output=embed` URL (no API key needed).
// Iframe loads lazily so it doesn't block LCP.
//
// MOBILE-FIRST SIZING:
//   - Mobile default: aspect-ratio 4:3 → 375px wide phone gets ~280px tall map.
//     Sized for visibility without dominating the small viewport.
//   - Tablet/Desktop: same aspect ratio scales up BUT capped at max-height 400px
//     so the map never blows up to fill the whole laptop screen.
//   - Override per-instance by passing `aspectRatio` (e.g. "16/10") or
//     `maxHeight` (pixels) if you need a different shape.

export interface Props {
  query?: string;
  zoom?: number;
  /** CSS aspect-ratio. Mobile-friendly default. */
  aspectRatio?: string;
  /** Desktop height cap in pixels (aspect-ratio still controls the shape). */
  maxHeight?: number;
  title?: string;
}

const {
  query = 'Orange County, CA',
  zoom = 10,
  aspectRatio = '4/3',
  maxHeight = 400,
  title = `Map of ${query} — Giraffe Window Cleaning service area`,
} = Astro.props;

const src = `https://maps.google.com/maps?q=${encodeURIComponent(query)}&z=${zoom}&output=embed`;
---

<div
  class="rounded-2xl overflow-hidden shadow-sm border-[3px] border-foreground w-full"
  style={`aspect-ratio: ${aspectRatio}; max-height: ${maxHeight}px;`}
>
  <iframe
    src={src}
    title={title}
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    style="border:0; display:block; width:100%; height:100%;"
    allowfullscreen
  ></iframe>
</div>
