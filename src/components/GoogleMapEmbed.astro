---
// Google Maps embed using the legacy `output=embed` URL (no API key needed).
// Iframe loads lazily so it doesn't block LCP.
//
// SIZING: uses an aspect-ratio container instead of fixed heights. Scales
// fluidly with whatever container width it's dropped in. Default is 16:10
// (slightly taller than 16:9) which gives Orange County room to breathe at
// zoom 10. Override with the `aspectRatio` prop ("4/3", "16/9", etc.) if
// you need a different shape per page.

export interface Props {
  query?: string;
  zoom?: number;
  /** CSS aspect-ratio value. Default 16/10. */
  aspectRatio?: string;
  /** Optional title for accessibility/SEO. */
  title?: string;
}

const {
  query = 'Orange County, CA',
  zoom = 10,
  aspectRatio = '16/10',
  title = `Map of ${query} — Giraffe Window Cleaning service area`,
} = Astro.props;

const src = `https://maps.google.com/maps?q=${encodeURIComponent(query)}&z=${zoom}&output=embed`;
---

<div
  class="rounded-2xl overflow-hidden shadow-sm border-[3px] border-foreground"
  style={`aspect-ratio: ${aspectRatio};`}
>
  <iframe
    src={src}
    title={title}
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    style="border:0; display:block; width:100%; height:100%;"
    allowfullscreen
  ></iframe>
</div>
