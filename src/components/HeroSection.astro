---
// Faithful port of Lovable's HeroSection.tsx.
// Inline SVG replaces lucide-react ArrowRight + Play to keep zero JS.
---

<header class="pt-24 pb-12 sm:pt-28 sm:pb-16 md:pt-36 md:pb-24 overflow-hidden">
  <div class="container mx-auto px-4 sm:px-6">
    <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
      <div>
        <div class="neo-badge bg-accent text-accent-foreground mb-5 sm:mb-6 text-sm sm:text-base">
          ✨ #1 Rated Window Cleaning in Orange County
        </div>

        <h1 class="text-[2.75rem] sm:text-5xl md:text-7xl font-heading font-bold leading-[0.95] tracking-tight mb-5 sm:mb-6">
          SPARKLING
          <br />
          <span class="text-primary">WINDOWS</span>
          <br />
          EVERY TIME
          <span class="sr-only"> — Window Cleaning in Orange County, CA</span>
        </h1>

        <p class="text-base sm:text-lg md:text-xl text-muted-foreground max-w-md mb-7 sm:mb-8 font-body">
          Professional window cleaning and window washing services across
          Orange County, CA. Whether you search for window cleaning or window
          washing, Giraffe Cleaning is Orange County's top-rated choice for
          streak-free results.
        </p>

        <div class="flex flex-col sm:flex-row sm:flex-wrap gap-3 sm:gap-4">
          <a href="#quote" class="neo-btn-primary w-full sm:w-auto justify-center">
            Get Free Quote
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="#services" class="neo-btn-secondary w-full sm:w-auto justify-center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="6 3 20 12 6 21 6 3"/></svg>
            Our Services
          </a>
        </div>
      </div>

      <div class="relative flex justify-center">
        <div class="relative">
          <div class="neo-card p-6 sm:p-8 md:p-10 rounded-3xl flex items-center justify-center bg-foreground">
            <img
              src="/logo.svg"
              alt="Giraffe Cleaning logo — professional window cleaning service in Orange County CA"
              width="250"
              height="362"
              fetchpriority="high"
              class="h-[160px] w-auto sm:h-[200px] md:h-[250px]"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
            />
            <div
              class="hidden h-[160px] w-[160px] sm:h-[200px] sm:w-[200px] md:h-[250px] md:w-[250px] items-center justify-center text-primary text-[120px] sm:text-[150px] md:text-[180px] font-heading font-black"
              aria-hidden="true"
            >G</div>
          </div>
          <div class="absolute -top-3 -right-3 sm:-top-4 sm:-right-4 z-10 neo-badge bg-coral text-coral-foreground text-xs sm:text-base">
            ⭐ 5-Star Rated
          </div>
          <div class="absolute -bottom-2 -left-2 sm:-bottom-3 sm:-left-3 z-10 neo-badge bg-accent text-accent-foreground text-xs sm:text-base">
            🏠 Happy Homes
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
