---
// Verbatim port of HowItWorksSection.tsx (yellow-band 3-step explainer).
import GiraffePatches from './GiraffePatches.astro';

const steps = [
  { num: '01', title: 'Get a Quote',       desc: "Fill out our quick form or give us a call. We'll set up a time that works for you." },
  { num: '02', title: 'We Show Up',        desc: 'Our uniformed team arrives on time with all eco-friendly supplies in hand.' },
  { num: '03', title: 'Sparkling Results', desc: 'Sit back and enjoy your streak-free, crystal-clear windows. Guaranteed.' },
];
---

<section id="how-it-works" class="py-12 sm:py-16 md:py-20 bg-yellow-300 relative overflow-hidden">
  <GiraffePatches />
  <div class="container mx-auto px-6 relative z-10">
    <h2 class="text-4xl md:text-6xl font-heading font-bold text-center mb-16">HOW IT WORKS</h2>

    <div class="flex flex-col md:flex-row items-center justify-center max-w-4xl mx-auto gap-8 md:gap-0">
      {steps.map((step, i) => (
        <div class="text-center flex-1">
          <div class="flex items-center justify-center mb-5">
            {i > 0  && <div class="hidden md:block h-[3px] bg-foreground flex-1" />}
            {i === 0 && <div class="hidden md:block flex-1" />}
            <div
              class="w-20 h-20 rounded-full border-[3px] border-foreground bg-background text-foreground flex items-center justify-center text-3xl font-heading font-bold shrink-0"
              style="box-shadow: var(--shadow-brutal);"
            >
              {step.num}
            </div>
            {i < steps.length - 1 && <div class="hidden md:block h-[3px] bg-foreground flex-1" />}
            {i === steps.length - 1 && <div class="hidden md:block flex-1" />}
          </div>
          <h3 class="font-heading font-bold text-2xl mb-2">{step.title}</h3>
          <p class="text-muted-foreground max-w-xs mx-auto">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
