---
// Wraps the QuoteForm React island with section chrome + heading.
// `client:load` hydrates the form on page load; the rest of the page ships zero JS.
import QuoteForm from '../islands/QuoteForm.tsx';
---

<section id="quote" class="py-12 sm:py-16 md:py-20 relative overflow-hidden" aria-label="Get a free quote">
  <div class="container mx-auto px-6">
    <div class="text-center mb-12">
      <div class="neo-badge bg-coral text-coral-foreground mb-4 mx-auto">💬 Free quote</div>
      <h2 class="text-4xl md:text-6xl font-heading font-bold">
        Get Your <span class="text-primary">Free Quote</span>
      </h2>
      <p class="text-muted-foreground text-lg mt-4 max-w-xl mx-auto">
        Same-day response, no obligation. Or just call (949) 315-7142.
      </p>
    </div>
    <QuoteForm client:load />
  </div>
</section>
