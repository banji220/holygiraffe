---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Page Not Found | Giraffe Window Cleaning';
const description = "Sorry, we couldn't find that page. Let us help you get back on track.";
---

<BaseLayout title={title} description={description} path="/404" noindex>
  <section class="flex-1 flex items-center justify-center py-32">
    <div class="text-center px-6">
      <p class="text-8xl md:text-[10rem] font-heading font-bold text-primary leading-none mb-4">404</p>
      <h1 class="text-3xl md:text-5xl font-heading font-bold mb-4">Page Not Found</h1>
      <p class="text-lg text-muted-foreground max-w-md mx-auto mb-8 font-body">
        Sorry, we couldn't find that page. Let us help you get back on track.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/" class="neo-btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Go Back Home
        </a>
        <a href="/get-a-quote" class="neo-btn-secondary">
          Get a Free Quote
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
