---
// Dynamic route: pre-renders one HTML file per service at build time.
// Reads from src/data/serviceData.ts (7 services).
//
// Note on routing precedence: this file is `[service].astro` (any single
// segment). Astro routes more specific patterns first, so requests for
// `/window-cleaning-irvine` go to `window-cleaning-[city].astro`.

import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteFormSection from '../components/QuoteFormSection.astro';
import services, { serviceMap } from '../data/serviceData';
import {
  serviceSchema,
  breadcrumbSchema,
  faqSchema,
  webPageSchema,
  howToSchema,
} from '../lib/schema';

export async function getStaticPaths() {
  return services.map((s) => ({
    params: { service: s.slug },
  }));
}

const { service: serviceSlug } = Astro.params;
const service = serviceMap.get(serviceSlug!);
if (!service) {
  return Astro.redirect('/404');
}

const path = `/${service.slug}`;
const title = service.title;
const description = service.metaDescription;

const cityNames: Record<string, string> = {
  'irvine': 'Irvine', 'newport-beach': 'Newport Beach', 'huntington-beach': 'Huntington Beach',
  'costa-mesa': 'Costa Mesa', 'laguna-beach': 'Laguna Beach', 'laguna-niguel': 'Laguna Niguel',
  'mission-viejo': 'Mission Viejo', 'lake-forest': 'Lake Forest',
  'rancho-santa-margarita': 'Rancho Santa Margarita',
  'san-clemente': 'San Clemente', 'dana-point': 'Dana Point', 'tustin': 'Tustin',
  'orange': 'Orange', 'anaheim': 'Anaheim', 'fullerton': 'Fullerton',
  'yorba-linda': 'Yorba Linda',
  'aliso-viejo': 'Aliso Viejo', 'san-juan-capistrano': 'San Juan Capistrano',
  'ladera-ranch': 'Ladera Ranch', 'coto-de-caza': 'Coto de Caza',
};

const related = service.related
  .map((slug) => serviceMap.get(slug))
  .filter((s): s is NonNullable<typeof s> => Boolean(s));

const schemas = [
  serviceSchema({ name: service.name, description: service.intro, slug: service.slug }),
  webPageSchema({ title, description, path }),
  breadcrumbSchema([{ name: service.name, path }]),
  ...(service.howItWorks.length > 0
    ? [howToSchema({
        name: `How ${service.name} Works`,
        description: service.intro,
        steps: service.howItWorks,
      })]
    : []),
  ...(service.faqs.length > 0 ? [faqSchema(service.faqs)] : []),
];

function renderLinks(text: string): string {
  return text.replace(
    /\[([^\]]+)\]\(([^)]+)\)/g,
    '<a href="$2" class="text-primary underline hover:text-primary/80 transition-colors">$1</a>',
  );
}

const headlineParts = service.headline.split(' in ');
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  {/* Breadcrumb */}
  <div class="container mx-auto px-4 sm:px-6 pt-24 pb-4">
    <nav aria-label="Breadcrumb" class="flex items-center gap-1 text-sm text-muted-foreground">
      <a href="/" class="hover:text-foreground transition-colors">Home</a>
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span>Services</span>
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-foreground font-medium">{service.name}</span>
    </nav>
  </div>

  {/* Hero */}
  <section class="container mx-auto px-4 sm:px-6 py-8 sm:py-12 md:py-20">
    <div class="max-w-3xl">
      <h1 class="text-3xl sm:text-4xl md:text-6xl font-heading font-bold mb-5 sm:mb-6 leading-tight">
        {headlineParts[0]}{headlineParts.length > 1 && (<>in <span class="text-primary">{headlineParts[1]}</span></>)}
      </h1>
      <p class="text-base sm:text-lg text-muted-foreground leading-relaxed mb-7 sm:mb-8">{service.intro}</p>
      <div class="flex flex-col sm:flex-row sm:flex-wrap gap-3 sm:gap-4">
        <a href="tel:+19493157142" aria-label="Call Giraffe Cleaning at (949) 315-7142" class="neo-btn neo-btn-primary inline-flex items-center gap-2 justify-center w-full sm:w-auto">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (949) 315-7142
        </a>
        <a href="/get-a-quote" class="neo-btn neo-btn-secondary inline-flex items-center gap-2 justify-center w-full sm:w-auto">
          Get Free Quote
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  {/* What's included */}
  <section class="container mx-auto px-6 py-12 overflow-hidden">
    <h2 class="text-3xl md:text-4xl font-heading font-bold mb-8">
      What's <span class="text-primary">Included</span>
    </h2>
    <div class="grid sm:grid-cols-2 gap-4 max-w-3xl">
      {service.benefits.map((b) => (
        <div class="neo-card p-4 border-[3px] border-foreground flex items-center gap-3">
          <svg class="w-5 h-5 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span class="font-heading font-bold text-sm">{b}</span>
        </div>
      ))}
    </div>
  </section>

  {/* Extended content */}
  {service.extendedContent.length > 0 && (
    <section class="container mx-auto px-6 py-12">
      <div class="max-w-3xl space-y-5">
        {service.extendedContent.map((p) => (
          <p class="text-muted-foreground leading-relaxed" set:html={renderLinks(p)} />
        ))}
      </div>
    </section>
  )}

  {/* Why choose us */}
  {service.whyChooseUs.length > 0 && (
    <section class="container mx-auto px-6 py-12 overflow-hidden">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-8">
        Why Choose <span class="text-primary">Giraffe Cleaning</span> for {service.name}
      </h2>
      <div class="grid sm:grid-cols-2 gap-4 max-w-3xl">
        {service.whyChooseUs.map((item) => (
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span class="text-sm font-heading font-semibold">{item}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  {/* How it works */}
  {service.howItWorks.length > 0 && (
    <section class="container mx-auto px-6 py-12 overflow-hidden">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-8">
        How It <span class="text-primary">Works</span>
      </h2>
      <div class="max-w-3xl space-y-6">
        {service.howItWorks.map((step) => (
          <div class="neo-card p-6 border-[3px] border-foreground flex gap-5 items-start">
            <span class="text-3xl font-heading font-black text-primary shrink-0">{step.num}</span>
            <div>
              <h3 class="font-heading font-bold text-lg mb-1">{step.title}</h3>
              <p class="text-muted-foreground text-sm leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {/* Pricing */}
  {service.pricingContent.length > 0 && (
    <section class="container mx-auto px-6 py-12">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-6">
        Pricing &amp; <span class="text-primary">Estimates</span>
      </h2>
      <div class="max-w-3xl space-y-5">
        {service.pricingContent.map((p) => (
          <p class="text-muted-foreground leading-relaxed" set:html={renderLinks(p)} />
        ))}
        <div class="pt-4">
          <a href="/get-a-quote" class="neo-btn neo-btn-primary inline-flex items-center gap-2">
            Get Your Free Quote
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>
  )}

  {/* FAQs */}
  {service.faqs.length > 0 && (
    <section class="container mx-auto px-6 py-12">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-8">
        Frequently Asked <span class="text-primary">Questions</span>
      </h2>
      <div class="max-w-3xl neo-faq space-y-3">
        {service.faqs.map((faq) => (
          <details class="neo-card border-[3px] border-foreground px-5 rounded-lg">
            <summary class="font-heading font-bold text-sm text-left flex items-center justify-between gap-3 py-3">
              <span class="flex items-center gap-2">
                <svg class="w-4 h-4 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
                {faq.question}
              </span>
            </summary>
            <div class="text-muted-foreground text-sm leading-relaxed pb-4 pt-1" set:html={renderLinks(faq.answer)} />
          </details>
        ))}
      </div>
    </section>
  )}

  {/* Available cities */}
  {service.cityLinks.length > 0 && (
    <section class="container mx-auto px-6 py-12">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-6">
        Available in These <span class="text-primary">Cities</span>
      </h2>
      <div class="flex flex-wrap gap-3">
        {service.cityLinks.map((slug) => (
          <a
            href={`/window-cleaning-${slug}`}
            class="neo-card p-3 px-5 border-[2px] border-foreground font-heading font-bold text-sm hover:border-primary hover:text-primary transition-colors"
          >
            {cityNames[slug] || slug}
          </a>
        ))}
        <a
          href="/get-a-quote"
          class="neo-card p-3 px-5 border-[2px] border-primary bg-primary/10 font-heading font-bold text-sm text-primary hover:bg-primary/20 transition-colors"
        >
          + All OC Cities →
        </a>
      </div>
    </section>
  )}

  {/* Final CTA */}
  <section class="container mx-auto px-6 py-12">
    <div class="neo-card border-[3px] border-foreground p-8 md:p-12 text-center max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">
        Get Your <span class="text-primary">Free Quote</span>
      </h2>
      <p class="text-muted-foreground mb-6 max-w-lg mx-auto">
        Ready for spotless results? Contact us today for a free, no-obligation
        estimate. We respond within hours — not days.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="tel:+19493157142" aria-label="Call Giraffe Cleaning at (949) 315-7142" class="neo-btn neo-btn-primary inline-flex items-center gap-2 justify-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (949) 315-7142
        </a>
        <a href="/get-a-quote" class="neo-btn neo-btn-secondary inline-flex items-center gap-2 justify-center">
          Request Free Quote
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <QuoteFormSection />

  {/* Related services */}
  {related.length > 0 && (
    <section class="container mx-auto px-6 py-12">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-8">
        Related <span class="text-primary">Services</span>
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {related.map((rs) => (
          <a href={`/${rs.slug}`} class="neo-card-hover p-5 flex items-center justify-between group">
            <span class="font-heading font-bold text-sm">{rs.name}</span>
            <svg class="w-4 h-4 text-muted-foreground group-hover:text-foreground transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
