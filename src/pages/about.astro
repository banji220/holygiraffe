---
// Verbatim port of Lovable's AboutPage.tsx (the part needed for fidelity).
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema, webPageSchema } from '../lib/schema';

const title = 'About Giraffe Cleaning — Orange County Window Cleaners';
const description =
  'Meet the team behind Giraffe Cleaning — Orange County\'s locally owned window cleaning company. Licensed, insured, eco-friendly. Learn our story.';
const path = '/about';

const values = [
  {
    icon: 'heart',
    title: 'Quality Over Shortcuts',
    description: "Every pane gets individual attention. We don't rush through jobs or cut corners to squeeze in more appointments. If a window isn't perfect, we re-clean it on the spot.",
  },
  {
    icon: 'shield',
    title: 'Respect for Your Property',
    description: 'Shoe covers indoors, drop cloths on sills, careful handling of screens and hardware. Your home is treated like our own — because our reputation depends on it.',
  },
  {
    icon: 'leaf',
    title: 'Eco-Friendly Methods',
    description: 'Our purified deionized water system eliminates the need for soaps and chemicals. Safe for your family, your pets, your landscaping, and the environment.',
  },
  {
    icon: 'users',
    title: 'Local Accountability',
    description: "We're not a franchise with a call center. When you call Giraffe Cleaning, you're talking to the people who actually clean your windows. Problems get solved in minutes, not days.",
  },
];

const iconPaths: Record<string, string> = {
  heart:  '<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/>',
  shield: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>',
  leaf:   '<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.3c1 3.2.7 7.7-1 11-1.4 2.7-4 5-7.2 5"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/>',
  users:  '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
};

const schemas = [
  webPageSchema({ title, description, path }),
  breadcrumbSchema([{ name: 'About', path }]),
];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  {/* Breadcrumb */}
  <div class="container mx-auto px-6 pt-24 pb-4">
    <nav aria-label="Breadcrumb" class="flex items-center gap-1 text-sm text-muted-foreground">
      <a href="/" class="hover:text-foreground transition-colors">Home</a>
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-foreground font-medium">About</span>
    </nav>
  </div>

  {/* Hero */}
  <section class="container mx-auto px-6 py-12 md:py-20">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-6xl font-heading font-bold mb-6">
        About Giraffe Cleaning — Orange County's <span class="text-primary">Local Window Cleaners</span>
      </h1>
      <p class="text-lg text-muted-foreground leading-relaxed mb-6">
        Giraffe Cleaning started with a simple idea: Orange County homeowners and
        businesses deserve window cleaning they can actually rely on. Not a crew
        that shows up late, rushes through the job, and leaves streaks behind.
        Not a franchise that sends a different person every time. A real, local
        company that takes pride in every single window.
      </p>
      <p class="text-lg text-muted-foreground leading-relaxed mb-6">
        That's exactly what we built. Based right here in Orange County, Giraffe
        Cleaning serves homeowners, property managers, HOAs, and small businesses
        from San Clemente to Yorba Linda. The name? Giraffes reach the highest
        places with ease — and so do we. Our water-fed pole system safely cleans
        windows up to four stories without ladders leaning against your walls.
      </p>
      <p class="text-lg text-muted-foreground leading-relaxed mb-8">
        We use a purified deionized water system that leaves zero residue — no
        soaps, no chemicals, just perfectly clean glass. Every technician is
        trained, background-checked, and carries $2 million in liability coverage.
        We show up on time, we communicate clearly, and we don't leave until
        you're satisfied.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="tel:+19493157142" aria-label="Call Giraffe Cleaning at (949) 315-7142" class="neo-btn neo-btn-primary inline-flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (949) 315-7142
        </a>
        <a href="/get-a-quote" class="neo-btn neo-btn-secondary inline-flex items-center gap-2">
          Get Free Quote
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  {/* Values */}
  <section class="container mx-auto px-6 py-12">
    <h2 class="text-3xl md:text-4xl font-heading font-bold mb-10">
      What We <span class="text-primary">Stand For</span>
    </h2>
    <div class="grid md:grid-cols-2 gap-6 max-w-5xl">
      {values.map((v) => (
        <div class="neo-card p-6">
          <div class="w-14 h-14 rounded-xl border-[3px] border-foreground bg-mint text-mint-foreground flex items-center justify-center mb-4" style="box-shadow: var(--shadow-brutal-sm);">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={iconPaths[v.icon]} />
          </div>
          <h3 class="font-heading font-bold text-xl mb-2">{v.title}</h3>
          <p class="text-muted-foreground leading-relaxed">{v.description}</p>
        </div>
      ))}
    </div>
  </section>

  {/* CTA */}
  <section class="container mx-auto px-6 py-16">
    <div class="neo-card p-8 md:p-12 text-center max-w-3xl mx-auto bg-primary text-primary-foreground border-[3px] border-foreground">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">
        Want to put us to work on your windows?
      </h2>
      <p class="text-primary-foreground/90 mb-6 max-w-lg mx-auto">
        Same-day callback, free written quote, no pushy upsells.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="tel:+19493157142" class="neo-btn bg-accent text-accent-foreground">Call (949) 315-7142</a>
        <a href="/get-a-quote" class="neo-btn bg-card text-foreground">Get a Free Quote</a>
      </div>
    </div>
  </section>
</BaseLayout>
